{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rewave",
  "version": "0.1.0",
  "identifier": "com.rewave.app",
  "build": {
    "frontendDist": "../rewave-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix ../rewave-ui",
    "beforeBuildCommand": "npm run build --prefix ../rewave-ui"
  },
  "app": {
    "windows": [
      {
        "title": "Rewave",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
